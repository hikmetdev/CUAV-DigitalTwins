# Gemini AI Copilot ayarları
# Bu dosyayı `config/.env` olarak kopyalayın ve değerleri doldurun.
# GERÇEK config/.env dosyası .gitignore ile korunur — ASLA commit etmeyin.

# Anahtarı https://aistudio.google.com/apikey adresinden alın (AIzaSy... formatında).
GEMINI_API_KEY=

# Function-calling modeli. Öneri: gemini-3.1-flash-lite (hızlı yanıt, düşük kota).
GEMINI_MODEL=gemini-3.1-flash-lite
