<?xml version="1.0"?>
<model>
  <name>SIHA Mini Talon V-Tail (kameralı)</name>
  <version>1.0</version>
  <sdf version="1.9">model.sdf</sdf>

  <description>
    ArduPilot mini_talon_vtail modelinin proje yerel kopyası. Orijinal yapıya
    ek olarak iki kamera bağlantısı (ön-aşağı ve tam alt) içerir; bunlar
    /camera/image ve /bottom_camera/image topic'lerini yayınlar. Görsel mesh'ler
    model://mini_talon_vtail/meshes yolundan (ArduPilot models klasörü) çözülür.
  </description>
</model>
